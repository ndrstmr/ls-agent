{% extends 'base.html.twig' %}

{% block title %}LS-KI Agent — Leichte Sprache mit Steg{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --bg: #f7f7f5;
        --fg: #1a1a1a;
        --muted: #6b6b6b;
        --accent: #0b5fff;
        --border: #d8d8d2;
        --success-bg: #eef6ee;
        --error-bg: #fdecec;
        --error-fg: #8a1f1f;
        --warning-bg: #fffaed;
        --warning-fg: #7d5f2e;
    }
    * { box-sizing: border-box; }
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        line-height: 1.5;
    }
    .wrap { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .nav-link {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
    }
    .nav-link:hover { text-decoration: underline; }
    h1 { margin: 0 0 0.25rem; font-size: 1.6rem; }
    .lead { color: var(--muted); margin: 0 0 2rem; }
    form > div + div { margin-top: 1rem; }
    label { display: block; font-weight: 600; margin-bottom: 0.35rem; }
    textarea, input[type="number"] {
        width: 100%;
        font: inherit;
        padding: 0.6rem 0.7rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
    }
    textarea { resize: vertical; min-height: 200px; font-family: ui-monospace, "SFMono-Regular", Menlo, monospace; font-size: 0.92rem; }
    .settings { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    input[type="checkbox"] { margin-right: 0.5rem; }
    .checkbox-label { display: flex; align-items: center; font-weight: normal; }
    button[type="submit"] {
        background: var(--accent);
        color: #fff;
        border: 0;
        padding: 0.7rem 1.2rem;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 1rem;
    }
    button[type="submit"]:hover { filter: brightness(1.05); }
    .tabs { display: flex; gap: 1rem; margin-top: 2rem; border-bottom: 1px solid var(--border); }
    .tab-button {
        background: none;
        border: none;
        padding: 0.75rem 1rem;
        cursor: pointer;
        font-weight: 600;
        color: var(--muted);
        border-bottom: 3px solid transparent;
        transition: all 0.2s;
    }
    .tab-button.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
    }
    .tab-content { display: none; margin-top: 1.5rem; }
    .tab-content.active { display: block; }
    .columns { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .col { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; }
    .col h2 { margin: 0 0 0.75rem; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); }
    .col.translated { background: var(--success-bg); }
    .col pre {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
        font-family: inherit;
        font-size: 1rem;
    }
    .result-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-bottom: 0.9rem;
        align-items: center;
    }
    .action-button {
        background: #fff;
        color: var(--fg);
        border: 1px solid var(--border);
        padding: 0.45rem 0.75rem;
        border-radius: 6px;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .action-button:hover { border-color: var(--accent); color: var(--accent); }
    .copy-feedback {
        font-size: 0.82rem;
        color: var(--muted);
    }
    .markdown-output {
        font-size: 1rem;
        line-height: 1.6;
    }
    .markdown-output p { margin: 0 0 0.8rem; }
    .markdown-output p:last-child { margin-bottom: 0; }
    .markdown-output ul,
    .markdown-output ol { margin: 0.4rem 0 0.8rem 1.25rem; }
    .raw-markdown { margin-top: 1rem; }
    .raw-markdown summary {
        cursor: pointer;
        color: var(--muted);
        font-size: 0.85rem;
    }
    .meta {
        margin-top: 0.75rem;
        font-size: 0.82rem;
        color: var(--muted);
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .meta code { background: rgba(0,0,0,0.05); padding: 1px 6px; border-radius: 3px; }
    .error {
        background: var(--error-bg);
        color: var(--error-fg);
        padding: 0.9rem 1rem;
        border-radius: 6px;
        margin-top: 1.5rem;
        border: 1px solid #e8c0c0;
    }
    .form-errors { color: var(--error-fg); font-size: 0.88rem; margin-top: 0.25rem; }
    .quality-score {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        padding: 1rem;
        border-radius: 6px;
        text-align: center;
    }
    .quality-score.high { background: var(--success-bg); color: #2d5f2e; }
    .quality-score.medium { background: var(--warning-bg); color: var(--warning-fg); }
    .quality-score.low { background: var(--error-bg); color: var(--error-fg); }
    .quality-issues { margin-top: 1rem; }
    .issue { margin: 1rem 0; padding: 0.9rem; border-left: 4px solid var(--border); background: rgba(0,0,0,0.02); border-radius: 4px; }
    .issue.high { border-left-color: #c41e1e; }
    .issue.medium { border-left-color: #d97b2f; }
    .issue.low { border-left-color: #4a7c59; }
    .issue-rule { font-weight: 600; color: var(--fg); }
    .issue-severity { display: inline-block; font-size: 0.75rem; font-weight: 600; padding: 2px 6px; border-radius: 3px; margin-left: 0.5rem; }
    .issue-severity.high { background: #ffcccc; color: #8a1f1f; }
    .issue-severity.medium { background: #fff3cd; color: #7d5f2e; }
    .issue-severity.low { background: #d4edda; color: #2d5f2e; }
    .issue-text { font-size: 0.9rem; color: var(--muted); margin: 0.5rem 0; font-style: italic; }
    .issue-suggestion { font-size: 0.9rem; background: rgba(11, 95, 255, 0.05); padding: 0.5rem; border-radius: 3px; margin-top: 0.5rem; }
    .quality-summary { font-size: 0.95rem; color: var(--fg); font-style: italic; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); }
    @media (max-width: 800px) {
        .columns { grid-template-columns: 1fr; }
        .settings { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="wrap">
    <div class="topbar">
        <h1>🌊 LS-KI Agent</h1>
    </div>
    <p class="lead">Verwaltungstexte in Leichte Sprache übersetzen — über Steg an ein lokales LLM.</p>

    {{ form_start(form) }}
        <div>
            {{ form_label(form.originalText) }}
            {{ form_widget(form.originalText) }}
            <div class="form-errors">{{ form_errors(form.originalText) }}</div>
        </div>

        <div class="settings">
            <div>
                {{ form_label(form.temperature) }}
                {{ form_widget(form.temperature) }}
                <div class="form-errors">{{ form_errors(form.temperature) }}</div>
            </div>
            <div>
                {{ form_label(form.maxTokens) }}
                {{ form_widget(form.maxTokens) }}
                <div class="form-errors">{{ form_errors(form.maxTokens) }}</div>
            </div>
        </div>

        {{ form_widget(form.submit) }}
    {{ form_end(form) }}

    {% if error %}
        <div class="error"><strong>Fehler:</strong> {{ error }}</div>
    {% endif %}

    {% if result %}
        <div class="tabs" id="result-tabs"
            data-quality-url="{{ path('app_quality_check')|e('html_attr') }}"
            data-audit-url="{{ path('app_audit_events')|e('html_attr') }}">
            <button class="tab-button active" data-tab="translation-result">Ergebnis</button>
            <button class="tab-button" data-tab="quality-check" id="tab-btn-quality">Qualitätscheck</button>
            <button class="tab-button" data-tab="audit-trail" id="tab-btn-audit">Audit Trail</button>
        </div>

        {# Tab 1: Ergebnis #}
        <div id="translation-result" class="tab-content active">
            <div class="columns">
                <div class="col">
                    <h2>Original</h2>
                    <pre>{{ result.originalText }}</pre>
                </div>
                <div class="col translated">
                    <h2>Leichte Sprache</h2>
                    <div class="result-actions">
                        <button id="copy-markdown" class="action-button" type="button">Markdown kopieren</button>
                        <button id="export-markdown" class="action-button" type="button">Als .md exportieren</button>
                        <button id="run-quality-check" class="action-button" type="button">
                            ✓ Qualitätscheck starten
                        </button>
                        <span id="copy-feedback" class="copy-feedback" aria-live="polite"></span>
                    </div>
                    <div id="translated-markdown" class="markdown-output"></div>
                    <script id="result-data" type="application/json">{{ {translatedText: result.translatedText, traceId: result.traceId}|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_HEX_TAG'))|raw }}</script>
                    <details class="raw-markdown">
                        <summary>Markdown-Quelle anzeigen</summary>
                        <pre id="translated-markdown-raw">{{ result.translatedText }}</pre>
                    </details>
                </div>
            </div>
            <div class="meta">
                <span>Trace: <code>{{ result.traceId }}</code></span>
                <span>Modell: <code>{{ result.model }}</code></span>
                <span>Prompt-Tokens: <code>{{ result.promptTokens }}</code></span>
                <span>Completion-Tokens: <code>{{ result.completionTokens }}</code></span>
                <span>Dauer: <code>{{ result.durationMs|number_format(0) }} ms</code></span>
            </div>
        </div>

        {# Tab 2: Qualitätscheck (async) #}
        <div id="quality-check" class="tab-content">
            <div id="quality-placeholder" style="color: var(--muted); margin-top: 1rem;">
                Klicke „Qualitätscheck starten" oder wechsle in diesen Tab nach dem Start.
            </div>
            <div id="quality-loading" style="display:none; color: var(--muted); margin-top: 1rem;">Prüfung läuft…</div>
            <div id="quality-result" style="display:none;"></div>
        </div>

        {# Tab 3: Audit Trail (async) #}
        <div id="audit-trail" class="tab-content">
            <div id="audit-loading" style="color: var(--muted); margin-top: 1rem;">Lade Audit-Events…</div>
            <div id="audit-table-wrap" style="display:none; overflow-x: auto; margin-top: 1rem;">
                <table style="width:100%; border-collapse: collapse; font-size: 0.88rem;">
                    <thead>
                        <tr style="background: rgba(0,0,0,0.04); text-align: left;">
                            <th style="padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border);">Zeit</th>
                            <th style="padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border);">Event</th>
                            <th style="padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border);">Status</th>
                            <th style="padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border);">Details</th>
                        </tr>
                    </thead>
                    <tbody id="audit-tbody"></tbody>
                </table>
            </div>
        </div>
    {% endif %}
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.6/dist/purify.min.js"></script>
<script>
// — Tab navigation —
document.querySelectorAll('.tab-button').forEach(button => {
    button.addEventListener('click', function(e) {
        e.preventDefault();
        const tabId = this.getAttribute('data-tab');
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
        document.getElementById(tabId)?.classList.add('active');
        this.classList.add('active');

        if (tabId === 'audit-trail') {
            loadAuditTrail();
        }
    });
});

// — Result data from JSON script tag —
const resultDataEl = document.getElementById('result-data');
const resultData = resultDataEl ? JSON.parse(resultDataEl.textContent) : {};
const markdownText = resultData.translatedText || '';
const resultTraceId = resultData.traceId || '';
const translatedMarkdownElement = document.getElementById('translated-markdown');

if (translatedMarkdownElement) {
    if (window.marked && window.DOMPurify) {
        translatedMarkdownElement.innerHTML = window.DOMPurify.sanitize(window.marked.parse(markdownText));
    } else {
        translatedMarkdownElement.textContent = markdownText;
    }
}

// — Copy / Export —
const copyButton = document.getElementById('copy-markdown');
const exportButton = document.getElementById('export-markdown');
const copyFeedback = document.getElementById('copy-feedback');

if (copyButton) {
    copyButton.addEventListener('click', async () => {
        try {
            await navigator.clipboard.writeText(markdownText);
            if (copyFeedback) copyFeedback.textContent = 'Markdown kopiert.';
        } catch {
            if (copyFeedback) copyFeedback.textContent = 'Kopieren fehlgeschlagen.';
        }
    });
}

if (exportButton) {
    exportButton.addEventListener('click', () => {
        const blob = new Blob([markdownText], { type: 'text/markdown;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'leichte-sprache-' + new Date().toISOString().replace(/[:T]/g, '-').slice(0, 19) + '.md';
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
    });
}

// — Qualitätscheck (AJAX) —
const qualityBtn = document.getElementById('run-quality-check');
let qualityLoaded = false;

function renderQualityResult(data) {
    const wrap = document.getElementById('quality-result');
    const score = data.score || 0;
    const scoreClass = score >= 80 ? 'high' : (score >= 60 ? 'medium' : 'low');

    let html = `<div class="quality-score ${scoreClass}">Score: ${score}/100</div>`;

    if (data.summary) {
        html += `<div class="quality-summary">${escapeHtml(data.summary)}</div>`;
    }

    if (data.issues && data.issues.length > 0) {
        html += '<div class="quality-issues"><h3>Erkannte Probleme</h3>';
        data.issues.forEach(issue => {
            const sev = escapeHtml(issue.severity || 'low');
            html += `<div class="issue ${sev}">
                <div>
                    <span class="issue-rule">${escapeHtml(issue.rule || 'Unbekannte Regel')}</span>
                    <span class="issue-severity ${sev}">${sev.toUpperCase()}</span>
                </div>
                ${issue.text ? `<div class="issue-text">„${escapeHtml(issue.text)}"</div>` : ''}
                ${issue.suggestion ? `<div class="issue-suggestion"><strong>Vorschlag:</strong> ${escapeHtml(issue.suggestion)}</div>` : ''}
            </div>`;
        });
        html += '</div>';
    }

    if (wrap) {
        wrap.innerHTML = html;
        wrap.style.display = 'block';
    }
    document.getElementById('quality-placeholder').style.display = 'none';
    document.getElementById('quality-loading').style.display = 'none';
}

async function runQualityCheck(translatedText, traceId) {
    if (qualityLoaded) return;
    qualityLoaded = true;

    // Switch to quality tab
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
    document.getElementById('quality-check').classList.add('active');
    document.getElementById('tab-btn-quality').classList.add('active');

    document.getElementById('quality-placeholder').style.display = 'none';
    document.getElementById('quality-loading').style.display = 'block';

    try {
        const response = await fetch(document.getElementById('result-tabs').dataset.qualityUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ translatedText, traceId }),
        });

        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const data = await response.json();
        renderQualityResult(data);
    } catch (err) {
        document.getElementById('quality-loading').style.display = 'none';
        document.getElementById('quality-placeholder').style.display = 'block';
        document.getElementById('quality-placeholder').textContent = 'Fehler beim Qualitätscheck: ' + err.message;
    }
}

if (qualityBtn) {
    qualityBtn.addEventListener('click', () => {
        runQualityCheck(markdownText, resultTraceId);
    });
}

// — Audit Trail (AJAX) —
let auditLoaded = false;

async function loadAuditTrail() {
    if (!resultTraceId) return;

    try {
        const url = document.getElementById('result-tabs').dataset.auditUrl + '?trace_id=' + encodeURIComponent(resultTraceId);
        const response = await fetch(url, { headers: { 'Accept': 'application/json' } });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const events = await response.json();

        const tbody = document.getElementById('audit-tbody');
        if (!tbody) return;

        if (!events.length) {
            tbody.innerHTML = '<tr><td colspan="4" style="padding: 0.75rem; color: var(--muted);">Keine Events gefunden.</td></tr>';
        } else {
            tbody.innerHTML = events.map(ev => {
                const time = ev.created_at ? new Date(ev.created_at).toLocaleTimeString('de-DE') : '–';
                const ctx = ev.context || {};
                const details = Object.entries(ctx)
                    .filter(([k]) => !['status', 'system_prompt', 'user_prompt', 'api_response'].includes(k))
                    .map(([k, v]) => `<code>${escapeHtml(k)}: ${escapeHtml(String(v).substring(0, 120))}</code>`)
                    .join(' ');
                const hasPrompt = ctx.system_prompt || ctx.api_response;
                const promptDetail = hasPrompt
                    ? `<details style="margin-top:0.3rem;"><summary style="cursor:pointer;font-size:0.8rem;color:var(--muted);">Prompt / API-Response</summary>`
                      + (ctx.system_prompt ? `<div style="margin-top:0.3rem;"><strong>System-Prompt:</strong><pre style="white-space:pre-wrap;font-size:0.78rem;max-height:200px;overflow:auto;background:rgba(0,0,0,0.03);padding:0.5rem;border-radius:4px;">${escapeHtml(ctx.system_prompt)}</pre></div>` : '')
                      + (ctx.user_prompt ? `<div style="margin-top:0.3rem;"><strong>User-Prompt:</strong><pre style="white-space:pre-wrap;font-size:0.78rem;max-height:200px;overflow:auto;background:rgba(0,0,0,0.03);padding:0.5rem;border-radius:4px;">${escapeHtml(ctx.user_prompt)}</pre></div>` : '')
                      + (ctx.api_response ? `<div style="margin-top:0.3rem;"><strong>API-Response:</strong><pre style="white-space:pre-wrap;font-size:0.78rem;max-height:200px;overflow:auto;background:rgba(0,0,0,0.03);padding:0.5rem;border-radius:4px;">${escapeHtml(ctx.api_response)}</pre></div>` : '')
                      + `</details>`
                    : '';
                return `<tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 0.5rem 0.75rem; white-space: nowrap;">${time}</td>
                    <td style="padding: 0.5rem 0.75rem;"><code>${escapeHtml(ev.event_type || '')}</code></td>
                    <td style="padding: 0.5rem 0.75rem;">${escapeHtml(ctx.status || '')}</td>
                    <td style="padding: 0.5rem 0.75rem; font-size: 0.82rem; color: var(--muted);">${details}${promptDetail}</td>
                </tr>`;
            }).join('');
        }

        document.getElementById('audit-loading').style.display = 'none';
        document.getElementById('audit-table-wrap').style.display = 'block';
        auditLoaded = true;
    } catch (err) {
        document.getElementById('audit-loading').textContent = 'Fehler beim Laden: ' + err.message;
    }
}

// — Helpers —
function escapeHtml(str) {
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
</script>
{% endblock %}
