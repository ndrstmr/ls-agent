# Local overrides for development only.
# Copy to .env.local and adjust values for your environment.
# Never commit real endpoints, credentials, or internal hostnames.

###> symfony/framework-bundle ###
APP_SECRET=change-me-in-.env.local
###< symfony/framework-bundle ###

###> ndrstmr/steg-bundle ###
# vLLM endpoint for Leichte-Sprache translation.
# Format: vllm://HOST:PORT/v1?model=MODEL_NAME
STEG_VLLM_DSN=vllm://localhost:8000/v1?model=llama-3.3-70b-awq
###< ndrstmr/steg-bundle ###

###> app/network ###
# Optional: set only if your environment requires explicit proxy bypass.
# NO_PROXY=localhost,127.0.0.1
# no_proxy=localhost,127.0.0.1
###< app/network ###

###> app/prompts ###
# Prompt version under config/prompts/
PROMPT_VERSION=v1.0
###< app/prompts ###
